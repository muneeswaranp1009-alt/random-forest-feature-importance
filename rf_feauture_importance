import pandas as pd
import matplotlib.pyplot as plt
import joblib
import os

from sklearn.model_selection import train_test_split
from sklearn.linear_model import LogisticRegression
from sklearn.metrics import accuracy_score 
from sklearn.metrics import classification_report
from sklearn.metrics import confusion_matrix
from sklearn.tree import DecisionTreeClassifier
from sklearn.ensemble import RandomForestClassifier

def train_placement_model():
    try:
        stud_data = pd.read_csv(r"C:\My Works\May\1st Week\3rd Day\students_data.csv")
        
        stud_data["Placement"] = stud_data["Placement"].map({"Yes": 1, "No": 0})
        stud_data["Internship"] = stud_data["Internship"].map({"Yes": 1, "No": 0})
        
        print("\n..........................Converted Data Set.......................\n")
        print(stud_data.head())
        
        x = stud_data[["CGPA", "Aptitude", "Communication", "Projects", "Internship"]]
        y = stud_data["Placement"]
        
        x_train, x_test, y_train, y_test = train_test_split(x, y, test_size=0.2, random_state=7)
        
        rf_model = RandomForestClassifier(max_depth = None,random_state = 7)
        rf_model.fit(x_train, y_train)
        
        prediction = rf_model.predict(x_test)
        print("\n..........................Prediction Values.......................\n")
        print(prediction)
        
        accuracy = accuracy_score(y_test, prediction)
        print("\n..........................Accuracy Score.......................")
        print(f"Accuracy {accuracy*100:.2f}%")
        
        classification = classification_report(y_test, prediction,target_names=["Not placed", "Placed"])
        print("\n.......................Classification Report.......................")
        print("\n")
        print(classification)
        
        confusion = confusion_matrix(y_test, prediction)
        print("\n.......................Confusion Matrix...........................")
        print("\n")
        print(confusion)
        
        print("\n ....................Feature Importances.........................\n")
        feature_importance =rf_model.feature_importances_
        for feature, importance in  zip(x.columns, feature_importance):
            print(f"{feature}:{importance*100:.2f}%")
        
        placement_count = stud_data["Placement"].value_counts()
        
        plt.bar(placement_count.index, placement_count.values)
        
        plt.xlabel("Placement")
        plt.ylabel("Count")
        plt.title("Placement Counts")
        
        plt.show()
        
        plt.scatter(stud_data["CGPA"], stud_data["Placement"])
        plt.xlabel("CGPA")
        plt.ylabel("Placement")
        plt.title("CGPA vs Placement")
        plt.grid(True)
        plt.show()
        
        joblib.dump(rf_model,"placement_model.pkl")
        print("\nModel saved successfully")
        
        return rf_model
    
    except FileNotFoundError:
        print("\n Error:Csv file path is wrong ,please check file path")
        return None
    except Exception as e:
        print(f"\n Error:Something Went wrong during training:{e}")
        return None
    

def predict_new_student(trained_engine):
    if trained_engine is None:
        print("\nModel is not run properly")
        return 
    
    # Loop added to prevent crash on wrong inputs!
    while True:
        try:
            new_stud = input("\nEnter the student details (CGPA, Aptitude, Communication, Projects, Internship) or type 'exit' to quit: ")
            
            if new_stud.strip().lower() == 'exit':
                print("Exiting prediction... Bye!")
                break
                
            after_data = [float(x.strip()) for x in new_stud.split(",")]
            if len(after_data) != 5:
                print("Please enter exactly 5 values.")
                continue
                
            new_stud_df = pd.DataFrame([after_data], columns=["CGPA", "Aptitude", "Communication", "Projects", "Internship"])
            
            probability = trained_engine.predict_proba(new_stud_df)
            not_placed_chance = probability[0][0] * 100
            placed_chance = probability[0][1] * 100
            
            print("\n.......................Probability...........................")
            print(f"Chance of not get place: {not_placed_chance:.2f}%")
            print(f"Chance of get place: {placed_chance:.2f}%")
            
            result = trained_engine.predict(new_stud_df)
            if result[0] == 1:
                print("\nThe student is likely to be placed")
            else:
                print("\nThe student is not likely to be placed")
                
        except ValueError:
            print("\n Float Error:Please enter the valid number, not letters (eg: 8.5, 80, 75, 2, 1)")
        except Exception as e:
            print(f"\nInput Handling error:{e}")
        
if __name__ == "__main__":
    
    dev_mode = True
    if dev_mode == False and os.path.exists("placement_model.pkl"):
        print("Loading data from hard disk!")
        model_instance = joblib.load("placement_model.pkl")
    else:
        print("Training new model...")
        model_instance = train_placement_model()
        
    predict_new_student(model_instance)